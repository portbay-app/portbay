# Rust / Cargo
target/
**/*.rs.bk

# Tauri
src-tauri/target/
src-tauri/gen/
src-tauri/gen/schemas
dist/

# SvelteKit
/build
/.svelte-kit
/package

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
docs-site/.vitepress/cache/
docs-site/.vitepress/dist/

# Node
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*

# Build / runtime
*.log
*.pid

# Local development — environment files (the committed template is .env.example)
.env
.env.*
!.env.example

# Secrets, credentials, and private config — never commit these. Proprietary
# Cloud/Pro configuration belongs in the private portbay-cloud repo, not here.
secrets/
.secrets-local/
*.secret
*.secret.*
config.local.*
.dev.vars

# Generated keys and certificates (local HTTPS is minted at runtime by mkcert)
*.pem
*.key
*.crt
*.p12
*.pfx
*.keystore
!src-tauri/**/fixtures/**/*.pem
rootCA*.pem

# Private / unsigned build artifacts
*.dmg
*.app.zip
release-notes-private.*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Agent / local tooling state (internal, not for the public repo)
.claude/

# OS
.DS_Store
Thumbs.db
src-tauri/binaries/process-compose-*
src-tauri/binaries/caddy-*
src-tauri/binaries/mkcert-*
src-tauri/binaries/mailpit-*
src-tauri/binaries/cloudflared-*
# Built from source by scripts/build-hosts-helper.sh, not committed.
src-tauri/binaries/portbay-hosts-helper-*
.playwright-mcp/
# Playwright E2E artifacts (interaction-latency harness).
test-results/
playwright-report/
