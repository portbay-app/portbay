{
  "name": "portbay",
  "version": "0.1.0",
  "description": "PortBay — lightweight local development environment manager.",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/portbay-app/portbay.git"
  },
  "scripts": {
    "prepare": "bash scripts/setup-hooks.sh || true",
    "boundaries": "bash scripts/check-repo-boundaries.sh",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "vite build",
    "test:e2e": "playwright test",
    "prescreenshots": "vite build",
    "screenshots": "playwright test --config playwright.screenshots.config.ts",
    "build:web": "PUBLIC_SIMULATOR=true vite build",
    "preview:web": "pnpm build:web && pnpm exec sirv build --single --host 127.0.0.1 --port 4318",
    "deploy:web": "pnpm build:web && npx wrangler deploy",
    "deploy:docs": "DOCS_BASE=/ pnpm docs:build && npx wrangler deploy -c wrangler.docs.jsonc",
    "deploy:all": "pnpm deploy:web && pnpm deploy:docs",
    "tauri": "tauri"
  },
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@lucide/svelte": "^1.16.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "ansi-to-html": "^0.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "sirv-cli": "^3.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7"
  }
}
