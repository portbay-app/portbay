<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- Hardened-runtime entitlements (tauri.conf.json → bundle.macOS.entitlements).
     Tauri signs with hardened runtime by default; without these the
     corresponding capabilities are hard-blocked at runtime no matter what
     Info.plist usage descriptions or TCC grants say. Same minimal set
     iTerm2/kitty ship. -->
<dict>
	<!-- System dictation (mic button on task cards): audio capture is
	     attributed to the app. Without this, a signed DMG build records
	     nothing — silently. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- Screen-recording webcam PiP (portbay-capture sidecar). Without this
	     the hardened runtime blocks AVCaptureSession video silently. -->
	<key>com.apple.security.device.camera</key>
	<true/>
	<!-- Agent-task dispatch drives Terminal/Warp/iTerm via Apple Events
	     (osascript). Pairs with NSAppleEventsUsageDescription in Info.plist. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
	<!-- The bundler signs every externalBin sidecar with THIS file, and the
	     bun-compiled portbay-agent (JavaScriptCore) needs JIT pages under
	     hardened runtime — without this it dies on launch with "Ran out of
	     executable memory" (SIGTRAP) in any release/notarized bundle, while
	     dev's ad-hoc signing hides the problem. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>
