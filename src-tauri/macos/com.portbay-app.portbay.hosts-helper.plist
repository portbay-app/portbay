<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.portbay-app.portbay.hosts-helper</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Applications/PortBay.app/Contents/MacOS/portbay-hosts-helper</string>
    <string>--socket</string>
    <string>/var/run/portbay-hosts-helper.sock</string>
    <string>--hosts-file</string>
    <string>/etc/hosts</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>MachServices</key>
  <dict/>
  <key>StandardOutPath</key>
  <string>/var/log/portbay-hosts-helper.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/portbay-hosts-helper.log</string>
</dict>
</plist>
