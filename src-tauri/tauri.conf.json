{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PortBay",
  "version": "0.1.4",
  "identifier": "com.portbay-app.portbay",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:clean",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "PortBay",
        "width": 1240,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "visible": false
      },
      {
        "label": "tray-panel",
        "url": "/tray-panel",
        "width": 360,
        "height": 560,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false,
        "acceptFirstMouse": true,
        "shadow": true
      },
      {
        "label": "dictation-overlay",
        "url": "/dictation-overlay",
        "width": 420,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false,
        "acceptFirstMouse": false,
        "shadow": false,
        "closable": false,
        "minimizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "appimage", "deb", "rpm"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/linux-freedesktop/16x16.png",
      "icons/linux-freedesktop/22x22.png",
      "icons/linux-freedesktop/24x24.png",
      "icons/linux-freedesktop/48x48.png",
      "icons/linux-freedesktop/64x64.png",
      "icons/linux-freedesktop/256x256.png",
      "icons/linux-freedesktop/scalable.svg",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/macos-liquid-glass/compiled/Assets.car": "Assets.car"
    },
    "externalBin": [
      "binaries/process-compose",
      "binaries/caddy",
      "binaries/mkcert",
      "binaries/mailpit",
      "binaries/cloudflared",
      "binaries/dnsmasq",
      "binaries/portbay-hosts-helper",
      "binaries/portbay-mcp"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "${APPLE_SIGNING_IDENTITY}",
      "entitlements": "./Entitlements.plist",
      "dmg": {
        "background": "icons/dmg-background.tiff",
        "windowSize": { "width": 540, "height": 380 },
        "appPosition": { "x": 130, "y": 220 },
        "applicationFolderPosition": { "x": 410, "y": 220 }
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2",
          "libsecret-1-0",
          "dnsmasq",
          "libnotify-bin",
          "policykit-1",
          "systemd"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator-gtk3",
          "librsvg2",
          "libsecret",
          "dbus",
          "dnsmasq",
          "libnotify",
          "polkit",
          "systemd"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBNEI4QjdFQzA4NkFBQjUKUldTMXFvYkFmb3RMT3J1MlZFdm51bDVlb3ZOU0cyNy94d0MvNjRKWGQ4eDRWUkxWR1poZ3VZMTgK",
      "endpoints": [
        "https://github.com/portbay-app/portbay/releases/latest/download/latest.json"
      ]
    }
  }
}
