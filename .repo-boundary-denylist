# .repo-boundary-denylist
#
# Strings that must NEVER appear in the public portbay-app repository.
# scripts/check-repo-boundaries.sh fails (locally and in CI) on any match.
#
# Each entry marks proprietary PortBay Cloud/Pro implementation, a secret, or a
# private endpoint that belongs ONLY in the private portbay-cloud repository.
# See docs/architecture/repo-boundaries.md for the full boundary policy.
#
# Format — three kinds of rule:
#   * `<string>`     forbidden CONTENT, matched as a fixed case-sensitive string.
#   * `re:<regex>`   forbidden CONTENT, matched as an extended regular expression.
#   * `path:<glob>`  forbidden PATH — this file may never be staged/committed,
#                    even with `git add -f` (it bypasses .gitignore, this does not).
#   Blank lines and lines beginning with `#` are ignored. In `path:` globs, `*`
#   matches across `/` (shell `case` semantics), so `secrets/*` and `*.pem` are
#   enough — no `**` needed.
#
# False positives (forbidden terms quoted in the boundary docs themselves,
# teaching examples, the committed `.env.example`) are excluded by path glob in
# `.repo-boundary-allow`. Add a glob there rather than weakening a rule here.

# --- Secret values / credentials (these never belong in version control) ---
STRIPE_SECRET
CUSTOMER_BILLING_SECRET
PAYMENT_WEBHOOK_SECRET
LICENSE_PRIVATE_KEY
ENTERPRISE_POLICY_SECRET
re:sk_live_[0-9A-Za-z]{16,}
re:sk_test_[0-9A-Za-z]{16,}
re:rk_live_[0-9A-Za-z]{16,}
re:-----BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY-----

# --- Private Cloud/Pro implementation markers ---
PORT_CLOUD_PRIVATE
CLOUD_INTERNAL
PRO_INTERNAL
PRIVATE_TUNNEL_SERVER

# --- Private endpoints (the public app calls documented PUBLIC APIs only) ---
internal.portbay
private.portbay
port-cloud.internal

# --- Private package namespaces (the public repo must not depend on these) ---
@portbay-cloud/

# --- Paths that must NEVER be committed (blocks even `git add -f`) ---
# Real environment files and secrets (the committed template `.env.example` is
# allowlisted in .repo-boundary-allow).
path:.env
path:.env.*
# Private keys / certificates / keystores.
path:*.pem
path:*.key
path:*.p12
path:*.pfx
path:*.keystore
path:*.jks
# Secret bundles and local-only secret stores.
path:secrets/*
path:.secrets-local/*
path:*.secret
path:.dev.vars
# Signed/unsigned distributables belong on Releases, not in git.
path:*.dmg
path:*.app.zip
# Internal compliance evidence (vendor DPA snapshots, secret-rotation runbooks).
# These document our private vendor relationships and embed vendor reCAPTCHA
# sitekeys / page hashes that secret scanners flag — they belong only in the
# private repo, never in public history.
path:docs/dpas/*

# --- Visual Preview Editor (Pro, private) — never in the public repo ---
# The Rust side is cfg-gated behind the private `visual-editor` feature, but
# the Svelte side ships in source — these paths must never land here.
path:src-tauri/src/live_preview/*
path:src-tauri/src/commands/live_preview.rs
path:src/lib/components/live-preview/*
path:src/routes/live-preview/*
path:src/lib/stores/livePreview.svelte.ts
path:src/lib/types/livePreview.ts
path:src/lib/data/stylingHints.ts
path:tests/e2e/visual-editor.spec.ts
path:tests/stylingHints.test.ts
# The browser-edit-bar vendored runtime helper (immerhin) ships only with the
# private build; never publish the tarball.
path:immerhin-*.tgz

# --- Confidential growth / marketing strategy — never in the public repo ---
# The marketing board and the install-metrics workflow embed growth targets,
# launch tactics, and references to the private growth-strategy docs. They are
# also .gitignored; this rule fails the public boundary check if either is ever
# force-added or pulled in by a wholesale `git add docs/`.
path:docs/MARKETING_BOARD.md
path:.github/workflows/install-metrics.yml

# --- Screen capture (Pro, private) — never in the public repo ---
# The portbay-capture sidecar (ScreenCaptureKit + camera PiP recorder) and its
# Rust supervisor / commands / UI ship only in the official Pro build. The
# shared plists and the Integrations hub stay public; these capture-specific
# paths do not.
path:src-tauri/capture/*
path:src-tauri/src/capture.rs
path:src-tauri/src/commands/capture.rs
path:src-tauri/binaries/portbay-capture-*
path:scripts/build-capture.sh
path:src/lib/components/settings/CapturePanel.svelte
path:src/lib/components/settings/RecordingControls.svelte
path:src/lib/components/permissions/CapturePermissionGate.svelte
path:src/routes/capture/*
